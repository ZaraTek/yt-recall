# ---- Backend (FastAPI) ----
# Google OAuth client ID used to verify incoming Google ID tokens
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
# Database name
MONGODB_DB=yt_recall
# Comma-separated list of allowed CORS origins for local dev
CORS_ORIGINS=http://localhost:5173
# Dev bypass: skip Google token verification and use a fixed local dev user
AUTH_DISABLED=false
# Gemini model to use (gemini-2.5-flash, gemini-2.5-pro, gemini-2.5-flash-lite)
GEMINI_MODEL=gemini-2.5-flash

# Optional: proxy to work around YouTube IP bans on transcript fetches.
# YouTube blocks cloud IPs (e.g. Vercel), so a rotating residential proxy is
# recommended for production. Webshare (residential package):
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
# Or a generic HTTP/HTTPS/SOCKS proxy:
PROXY_HTTP_URL=
PROXY_HTTPS_URL=

# ---- Frontend (Vite) ----
# Same Google client ID, exposed to the browser
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Base URL for the API. Leave empty in production (same origin /api).
VITE_API_BASE=http://localhost:8000
# Dev bypass: skip Google sign-in in the UI (must match backend AUTH_DISABLED)
VITE_AUTH_DISABLED=false
